"""
LLM pipeline steps: P2, Step 1, Step 2A, Step 3, Step 4.

Each function:
  - Receives typed inputs from previous stage
  - Renders the prompt via templates.py
  - Calls the LLM via LLMClient
  - Parses and validates the JSON response
  - Returns a typed output dataclass

No prompt text lives here — see prompts/templates.py.
"""

from __future__ import annotations

import dataclasses
import json
import logging
import re
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path
from typing import Any, Optional

from models.data_models import (
    CapabilitySpec,
    ClassifiedClause,
    Classification,
    EntitySpec,
    FileReferenceGraph,
    InterfaceSpec,
    NeedsReviewItem,
    RawClause,
    RawScores,
    SectionBundle,
    SectionItem,
    SkillPackage,
    SPLSpec,
    SuccessCriteria,
    WorkflowStepSpec,
)
from pipeline.llm_client import LLMClient, LLMParseError
from prompts import templates

logger = logging.getLogger(__name__)


# ─────────────────────────────────────────────────────────────────────────────
# P2 — File Role Resolver
# ─────────────────────────────────────────────────────────────────────────────

def run_p2_file_role_resolver(
    graph: FileReferenceGraph,
    client: LLMClient,
) -> dict[str, Any]:
    """
    P2: Determine the role and read priority of every non-SKILL.md file.

    Instead of sending the full SKILL.md, we extract only the sentences that
    reference other files (with ±1 line context).  This preserves the tone
    information the LLM needs while cutting token usage significantly.

    SKILL.md itself is always role="primary", read_priority=1 — fixed, not
    sent to the LLM for classification.

    Returns:
        dict mapping rel_path → FileRoleEntry dict (JSON-serializable).
        SKILL.md entry is added by this function, not by the LLM.
    """
    skill_md_references = _extract_skill_md_references(graph.skill_md_content, graph.edges)
    nodes_summary = _format_nodes_summary(graph)
    edges_json    = json.dumps(graph.edges, indent=2)

    user_prompt = templates.render_p2_user(
        skill_md_references=skill_md_references,
        nodes_summary=nodes_summary,
        edges_json=edges_json,
    )

    raw = client.call_json(
        step_name="p2_file_role_resolver",
        system=templates.P2_SYSTEM,
        user=user_prompt,
    )

    if isinstance(raw, dict) and "file_roles" in raw:
        file_roles = raw["file_roles"]
    else:
        file_roles = raw

    # Always inject SKILL.md as primary — the LLM doesn't output it
    file_roles["SKILL.md"] = {
        "role": "primary",
        "read_priority": 1,
        "must_read_for_normalization": True,
        "reasoning": "SKILL.md is the fixed anchor of every skill package.",
    }

    _validate_file_role_map(file_roles, graph)
    logger.info("[P2] resolved roles for %d files", len(file_roles))
    return file_roles


def _extract_skill_md_references(skill_md_content: str, edges: dict) -> str:
    """
    Extract lines from SKILL.md that reference other files, with ±1 line context.

    This gives the LLM the referencing tone (imperative vs optional) without
    sending the full SKILL.md content.
    """
    # Collect all basenames that SKILL.md references (from edges)
    referenced_names: set[str] = set()
    skill_md_refs = edges.get("SKILL.md", [])
    for ref_path in skill_md_refs:
        referenced_names.add(Path(ref_path).name.lower())

    if not referenced_names:
        return "(SKILL.md references no other files directly)"

    lines = skill_md_content.splitlines()
    result_blocks: list[str] = []
    seen_lines: set[int] = set()

    for i, line in enumerate(lines):
        line_lower = line.lower()
        if any(name in line_lower for name in referenced_names):
            # Include ±1 line context
            start = max(0, i - 1)
            end   = min(len(lines), i + 2)
            block_lines = []
            for j in range(start, end):
                if j not in seen_lines:
                    prefix = ">>>" if j == i else "   "
                    block_lines.append(f"{prefix} {lines[j]}")
                    seen_lines.add(j)
            if block_lines:
                result_blocks.append("\n".join(block_lines))

    return "\n\n".join(result_blocks) if result_blocks else "(no reference lines found)"


def _format_nodes_summary(graph: FileReferenceGraph) -> str:
    lines = []
    for path, node in sorted(graph.nodes.items()):
        head = " | ".join(node.head_lines[:3]) if node.head_lines else "(empty)"
        lines.append(f"  {path} [{node.kind}, {node.size_bytes}B]: {head}")
    return "\n".join(lines)


def _validate_file_role_map(file_roles: dict, graph: FileReferenceGraph) -> None:
    """Warn if any graph node is missing from the LLM output. SKILL.md is always injected."""
    for path in graph.nodes:
        if path == "SKILL.md":
            continue  # always injected by run_p2_file_role_resolver, not the LLM
        if path not in file_roles:
            logger.warning("[P2] no role assigned for: %s — defaulting to omit", path)
            file_roles[path] = {
                "role": "unreferenced",
                "read_priority": 3,
                "must_read_for_normalization": False,
                "reasoning": "No role returned by LLM; defaulting to omit.",
            }


# ─────────────────────────────────────────────────────────────────────────────
# P3 — LLM summarize_fn factory
# ─────────────────────────────────────────────────────────────────────────────

_P3_SUMMARIZE_SYSTEM = """\
You are a technical documentation summarizer.
Given the content of a file from a software skill package, write a concise
summary of 2-3 sentences that captures:
  - what this file does / what it contains
  - what inputs it expects and what it produces (if applicable)
  - any important constraints or notes

Output only the summary sentences. No headers, no lists, no markdown.
"""

def make_p3_summarize_fn(client: LLMClient):
    """
    Return a summarize_fn(rel_path, content) -> str for use in P3.

    Called only when a priority-2 file has empty head_lines.
    Produces a 2-3 sentence LLM summary from up to 4000 chars of file content.
    """
    def summarize(rel_path: str, content: str) -> str:
        user = f"File: {rel_path}\n\n{content}"
        return client.call(
            step_name=f"p3_summarize_{Path(rel_path).name}",
            system=_P3_SUMMARIZE_SYSTEM,
            user=user,
        )
    return summarize


# ─────────────────────────────────────────────────────────────────────────────
# Step 1 — Structure Extraction
# ─────────────────────────────────────────────────────────────────────────────

_SECTION_KEYS = ["INTENT", "WORKFLOW", "CONSTRAINTS", "TOOLS",
                 "ARTIFACTS", "EVIDENCE", "EXAMPLES", "NOTES"]

def run_step1_structure_extraction(
    package: SkillPackage,
    client: LLMClient,
) -> SectionBundle:
    """
    Step 1: Parse the assembled skill package into 8 canonical sections.
    All text is copied verbatim from source. Nothing is dropped.

    Returns:
        SectionBundle with verbatim items per section.
    """
    user_prompt = templates.render_step1_user(
        merged_doc_text=package.merged_doc_text,
    )

    raw = client.call_json(
        step_name="step1_structure_extraction",
        system=templates.STEP1_SYSTEM,
        user=user_prompt,
    )

    bundle = _parse_section_bundle(raw)
    total  = sum(len(getattr(bundle, s.lower())) for s in _SECTION_KEYS)
    logger.info("[Step 1] extracted %d items across all sections", total)
    return bundle


def _parse_section_bundle(raw: dict) -> SectionBundle:
    """Convert the LLM JSON response into a typed SectionBundle."""
    def parse_items(key: str) -> list[SectionItem]:
        items = raw.get(key, raw.get(key.lower(), []))
        result = []
        for item in items:
            if isinstance(item, dict):
                result.append(SectionItem(
                    text=item.get("text", ""),
                    source=item.get("source", "unknown"),
                    multi=item.get("multi", False),
                ))
            elif isinstance(item, str):
                result.append(SectionItem(text=item, source="unknown"))
        return result

    return SectionBundle(
        intent=parse_items("INTENT"),
        workflow=parse_items("WORKFLOW"),
        constraints=parse_items("CONSTRAINTS"),
        tools=parse_items("TOOLS"),
        artifacts=parse_items("ARTIFACTS"),
        evidence=parse_items("EVIDENCE"),
        examples=parse_items("EXAMPLES"),
        notes=parse_items("NOTES"),
    )


# ─────────────────────────────────────────────────────────────────────────────
# Step 2A — Clause Extraction + Scoring
# ─────────────────────────────────────────────────────────────────────────────

def run_step2a_clause_extraction(
    bundle: SectionBundle,
    client: LLMClient,
) -> list[RawClause]:
    """
    Step 2A: Extract normative clauses from all sections and score each on
    the 6 rubric dimensions (O, A, F, C, R, V).

    All sections are passed — the LLM decides what is normative.
    TOOLS may contain normative statements ("must use X for Y").

    Returns:
        List of RawClause objects with scores and is_normative flags.
    """
    section_text = bundle.to_text()   # all sections

    user_prompt = templates.render_step2a_user(
        section_bundle_text=section_text,
    )

    raw = client.call_json(
        step_name="step2a_clause_extraction",
        system=templates.STEP2A_SYSTEM,
        user=user_prompt,
    )

    if not isinstance(raw, list):
        # Some LLMs wrap the array: {"clauses": [...]}
        if isinstance(raw, dict):
            raw = raw.get("clauses", raw.get("items", []))

    clauses = [_parse_raw_clause(item, i) for i, item in enumerate(raw)]
    normative = sum(1 for c in clauses if c.is_normative)
    logger.info("[Step 2A] extracted %d clauses (%d normative)", len(clauses), normative)
    return clauses


def _parse_raw_clause(item: dict, index: int) -> RawClause:
    scores_raw = item.get("scores", {})
    scores = RawScores(
        O=int(scores_raw.get("O", 0)),
        A=int(scores_raw.get("A", 0)),
        F=int(scores_raw.get("F", 0)),
        C=int(scores_raw.get("C", 0)),
        R=int(scores_raw.get("R", 0)),
        V=int(scores_raw.get("V", 0)),
    )
    try:
        scores.validate()
    except ValueError as exc:
        logger.warning("[Step 2A] score validation failed for clause %d: %s", index, exc)
        # Clamp to valid range rather than failing the whole run
        scores = RawScores(
            O=max(0, min(3, scores.O)),
            A=max(0, min(3, scores.A)),
            F=max(0, min(3, scores.F)),
            C=max(0, min(3, scores.C)),
            R=max(0, min(3, scores.R)),
            V=max(0, min(3, scores.V)),
        )

    sub_clauses_raw = item.get("sub_clauses", [])
    sub_clauses = [_parse_raw_clause(s, index * 100 + i)
                   for i, s in enumerate(sub_clauses_raw)]

    return RawClause(
        clause_id=item.get("clause_id", f"c-{index:03d}"),
        source_section=item.get("source_section", "UNKNOWN"),
        source_file=item.get("source_file", "unknown"),
        original_text=item.get("original_text", ""),
        is_normative=bool(item.get("is_normative", True)),
        split=bool(item.get("split", False)),
        sub_clauses=sub_clauses,
        scores=scores,
        score_rationale=item.get("score_rationale", ""),
    )


# ─────────────────────────────────────────────────────────────────────────────
# Step 3 — Entity & Interface Inference
# ─────────────────────────────────────────────────────────────────────────────

def run_step3_interface_inference(
    bundle: SectionBundle,
    classified_clauses: list[ClassifiedClause],
    client: LLMClient,
) -> InterfaceSpec:
    """
    Step 3: Infer the latent interface of the skill.

    Inputs to the LLM:
      - WORKFLOW, TOOLS, ARTIFACTS sections (structural context)
      - HARD + MEDIUM classified clauses only (gates that reference entities)

    Returns:
        InterfaceSpec with capabilities, entities, workflow steps,
        success criteria, and needs_review_items.
    """
    workflow_text   = bundle.to_text(["WORKFLOW"])
    tools_text      = bundle.to_text(["TOOLS"])
    artifacts_text  = bundle.to_text(["ARTIFACTS"])

    hard_medium = [
        c for c in classified_clauses
        if c.classification in (Classification.HARD, Classification.MEDIUM)
    ]
    hard_medium_json = json.dumps(
        [_classified_clause_to_dict(c) for c in hard_medium],
        indent=2,
    )

    user_prompt = templates.render_step3_user(
        workflow_section=workflow_text,
        tools_section=tools_text,
        artifacts_section=artifacts_text,
        hard_medium_clauses_json=hard_medium_json,
    )

    raw = client.call_json(
        step_name="step3_interface_inference",
        system=templates.STEP3_SYSTEM,
        user=user_prompt,
    )

    spec = _parse_interface_spec(raw)
    logger.info(
        "[Step 3] inferred %d capabilities, %d entities, %d steps",
        len(spec.capabilities), len(spec.entities), len(spec.workflow_steps),
    )
    return spec


def _classified_clause_to_dict(c: ClassifiedClause) -> dict:
    return {
        "clause_id":         c.clause_id,
        "original_text":     c.original_text,
        "source_section":    c.source_section,
        "source_file":       c.source_file,
        "classification":    c.classification.value,
        "confidence":        c.confidence,
        "needs_review":      c.needs_review,
        "risk_override":     c.risk_override,
        "enforcement_backends": c.enforcement_backends,
        "scores": dataclasses.asdict(c.scores),
    }


def _parse_interface_spec(raw: dict) -> InterfaceSpec:
    def parse_capabilities(items: list) -> list[CapabilitySpec]:
        result = []
        for item in items:
            result.append(CapabilitySpec(
                cap_id=item.get("cap_id", ""),
                inputs=item.get("inputs", []),
                outputs=item.get("outputs", []),
                effects=item.get("effects", []),
                provenance=item.get("provenance", "LOW_CONFIDENCE"),
                source_text=item.get("source_text", ""),
            ))
        return result

    def parse_entities(items: list) -> list[EntitySpec]:
        result = []
        for item in items:
            result.append(EntitySpec(
                entity_id=item.get("entity_id", ""),
                kind=item.get("kind", "Artifact"),
                type_name=item.get("type_name", ""),
                schema_notes=item.get("schema_notes", ""),
                provenance_required=bool(item.get("provenance_required", False)),
                provenance=item.get("provenance", "LOW_CONFIDENCE"),
                source_text=item.get("source_text", ""),
            ))
        return result

    def parse_steps(items: list) -> list[WorkflowStepSpec]:
        result = []
        for item in items:
            result.append(WorkflowStepSpec(
                step_id=item.get("step_id", ""),
                capability=item.get("capability", ""),
                prerequisites=item.get("prerequisites", []),
                produces=item.get("produces", []),
                provenance=item.get("provenance", "ASSUMED"),
                source_text=item.get("source_text", ""),
            ))
        return result

    def parse_success(item: dict) -> SuccessCriteria:
        return SuccessCriteria(
            description=item.get("description", ""),
            deterministic=bool(item.get("deterministic", False)),
            provenance=item.get("provenance", "LOW_CONFIDENCE"),
            source_text=item.get("source_text", ""),
        )

    def parse_needs_review(items: list) -> list[NeedsReviewItem]:
        return [
            NeedsReviewItem(
                item=i.get("item", ""),
                reason=i.get("reason", ""),
                question=i.get("question", ""),
            )
            for i in items
        ]

    sc_raw = raw.get("success_criteria", {})
    return InterfaceSpec(
        capabilities=parse_capabilities(raw.get("capabilities", [])),
        entities=parse_entities(raw.get("entities", [])),
        workflow_steps=parse_steps(raw.get("workflow_steps", [])),
        success_criteria=parse_success(sc_raw if isinstance(sc_raw, dict) else {}),
        needs_review_items=parse_needs_review(raw.get("needs_review_items", [])),
    )


# ─────────────────────────────────────────────────────────────────────────────
# Step 4 — SPL Emission (sectioned multi-call)
# ─────────────────────────────────────────────────────────────────────────────

def run_step4_spl_emission(
    bundle: SectionBundle,
    classified_clauses: list[ClassifiedClause],
    interface_spec: InterfaceSpec,
    skill_id: str,
    client: LLMClient,
) -> SPLSpec:
    """
    Step 4: Emit the final normalized SPL specification in multiple focused calls.

    Execution plan
    ──────────────
    Round 1 — independent blocks (can be parallelised in future):
      4a  PERSONA / AUDIENCE / CONCEPTS
      4b  DEFINE_CONSTRAINTS
      4c  DEFINE_VARIABLES + DEFINE_FILES
      4d  DEFINE_APIS + DEFINE_GUARDRAIL

    After Round 1: extract symbol table (defined names) from 4b, 4c, 4d.

    Round 2 — depends on symbol table:
      4e  DEFINE_WORKER (MAIN_FLOW + ALTERNATIVE_FLOW + EXCEPTION_FLOW + EXAMPLES)

    Final: assemble blocks in canonical order + build Review Summary.
    """
    inputs = _prepare_step4_inputs(bundle, classified_clauses, interface_spec)

    # ── Round 1 — parallel ────────────────────────────────────────────────────
    # The four blocks are mutually independent; fire them concurrently to
    # reduce wall-clock time.  Each sub-call uses the same LLMClient (thread-
    # safe: the underlying Anthropic SDK is stateless per request).
    logger.info("[Step 4] Round 1: launching 4 parallel block generators")

    def call_4a() -> str:
        return client.call("step4a_persona", templates.S4A_SYSTEM,
                           templates.render_s4a_user(inputs["context_text"]))

    def call_4b() -> str:
        if not inputs["has_constraints"]:
            return ""
        return client.call("step4b_constraints", templates.S4B_SYSTEM,
                           templates.render_s4b_user(inputs["constraints_json"]))

    def call_4c() -> str:
        if not inputs["has_entities"]:
            return ""
        return client.call("step4c_variables_files", templates.S4C_SYSTEM,
                           templates.render_s4c_user(inputs["entities_json"]))

    def call_4d() -> str:
        if not inputs["has_ext_caps"]:
            return ""
        return client.call("step4d_apis_guardrail", templates.S4D_SYSTEM,
                           templates.render_s4d_user(inputs["ext_caps_json"]))

    with ThreadPoolExecutor(max_workers=4) as pool:
        fut_4a = pool.submit(call_4a)
        fut_4b = pool.submit(call_4b)
        fut_4c = pool.submit(call_4c)
        fut_4d = pool.submit(call_4d)
        block_4a = fut_4a.result()
        block_4b = fut_4b.result()
        block_4c = fut_4c.result()
        block_4d = fut_4d.result()

    # ── Symbol table extraction ───────────────────────────────────────────────
    symbol_table = _extract_symbol_table(block_4b, block_4c, block_4d)
    logger.info("[Step 4] Symbol table: %d names extracted", len(symbol_table))

    # ── Round 2 ───────────────────────────────────────────────────────────────
    logger.info("[Step 4] Round 2: generating WORKER")
    symbol_table_text = _format_symbol_table(symbol_table)
    s4e_system, s4e_user = templates.render_s4e_user(
        workflow_steps_json=inputs["workflow_steps_json"],
        workflow_prose=inputs["workflow_prose"],
        medium_clauses_json=inputs["medium_clauses_json"],
        non_comp_json=inputs["non_comp_json"],
        success_and_examples=inputs["success_and_examples"],
        symbol_table=symbol_table_text,
    )

    block_4e = client.call(
        step_name="step4e_worker",
        system=s4e_system,
        user=s4e_user,
    )

    # ── Assemble ──────────────────────────────────────────────────────────────
    spl_text = _assemble_spl(skill_id, block_4a, block_4b, block_4c, block_4d, block_4e)
    review_summary = _build_review_summary(classified_clauses, interface_spec)
    clause_counts = _count_clauses(classified_clauses)

    logger.info("[Step 4] SPL assembled (%d chars, %d LLM calls)",
                len(spl_text), 4 + (1 if inputs["has_ext_caps"] else 0))
    return SPLSpec(
        skill_id=skill_id,
        spl_text=spl_text,
        review_summary=review_summary,
        clause_counts=clause_counts,
    )


# ── Step 4 input preparation ──────────────────────────────────────────────────

def _prepare_step4_inputs(
    bundle: SectionBundle,
    classified_clauses: list[ClassifiedClause],
    interface_spec: InterfaceSpec,
) -> dict:
    """
    Pre-compute all inputs for the five Step 4 calls.  Each value is a plain
    string (text or JSON) ready to drop into a prompt template.
    """
    # 4a: context
    context_text = bundle.to_text(["INTENT", "NOTES"])

    # 4b: HARD + SOFT clauses only
    hard_soft = [
        c for c in classified_clauses
        if c.classification in (Classification.HARD, Classification.SOFT)
    ]
    constraints_json = json.dumps(
        [{"clause_id": c.clause_id,
          "tier": c.classification.value,
          "original_text": c.original_text,
          "confidence": c.confidence,
          "needs_review": c.needs_review,
          "risk_override": c.risk_override,
          "source_file": c.source_file}
         for c in hard_soft],
        indent=2, ensure_ascii=False,
    )

    # 4c: all entities
    entities_json = json.dumps(
        [{"entity_id": e.entity_id,
          "kind": e.kind,
          "type_name": e.type_name,
          "schema_notes": e.schema_notes,
          "provenance_required": e.provenance_required,
          "provenance": e.provenance,
          "source_text": e.source_text}
         for e in interface_spec.entities],
        indent=2, ensure_ascii=False,
    )

    # 4d: EXPLICIT caps with EXEC or NETWORK effects
    ext_caps = [
        c for c in interface_spec.capabilities
        if c.provenance == "EXPLICIT"
        and any(e in c.effects for e in ("NETWORK", "EXEC"))
    ]
    ext_caps_json = json.dumps(
        [{"cap_id": c.cap_id,
          "inputs": c.inputs,
          "outputs": c.outputs,
          "effects": c.effects,
          "source_text": c.source_text}
         for c in ext_caps],
        indent=2, ensure_ascii=False,
    )

    # 4e: workflow steps
    workflow_steps_json = json.dumps(
        [{"step_id": s.step_id,
          "capability": s.capability,
          "prerequisites": s.prerequisites,
          "produces": s.produces,
          "provenance": s.provenance,
          "source_text": s.source_text}
         for s in interface_spec.workflow_steps],
        indent=2, ensure_ascii=False,
    )
    workflow_prose = bundle.to_text(["WORKFLOW"])

    medium_clauses = [c for c in classified_clauses if c.classification == Classification.MEDIUM]
    medium_clauses_json = json.dumps(
        [{"clause_id": c.clause_id,
          "original_text": c.original_text,
          "confidence": c.confidence,
          "needs_review": c.needs_review,
          "source_file": c.source_file}
         for c in medium_clauses],
        indent=2, ensure_ascii=False,
    )

    non_comp = [c for c in classified_clauses if c.classification == Classification.NON]
    non_comp_json = json.dumps(
        [{"clause_id": c.clause_id,
          "original_text": c.original_text,
          "source_file": c.source_file}
         for c in non_comp],
        indent=2, ensure_ascii=False,
    )

    sc = interface_spec.success_criteria
    examples_text = bundle.to_text(["EXAMPLES"])
    success_parts = []
    if sc.description:
        success_parts.append(
            f"Success criteria (provenance: {sc.provenance}, "
            f"deterministic: {sc.deterministic}):\n  {sc.description}"
        )
    if examples_text.strip():
        success_parts.append("Original examples:\n" + examples_text)
    success_and_examples = "\n\n".join(success_parts) if success_parts else "(none)"

    return {
        "context_text":         context_text,
        "constraints_json":     constraints_json,
        "entities_json":        entities_json,
        "ext_caps_json":        ext_caps_json,
        "workflow_steps_json":  workflow_steps_json,
        "workflow_prose":       workflow_prose,
        "medium_clauses_json":  medium_clauses_json,
        "non_comp_json":        non_comp_json,
        "success_and_examples": success_and_examples,
        "has_constraints":      bool(hard_soft),
        "has_entities":         bool(interface_spec.entities),
        "has_ext_caps":         bool(ext_caps),
    }


# ── Symbol table ──────────────────────────────────────────────────────────────

# Patterns that identify defined names in each block type
_CONSTRAINT_NAME_RE = re.compile(r'^\s{1,12}([A-Z][A-Za-z0-9]+):\s', re.MULTILINE)
_VARIABLE_NAME_RE   = re.compile(r'^\s{1,12}"[^"]+"\s+(?:READONLY\s+)?([a-z][a-z0-9_]+):', re.MULTILINE)
_FILE_NAME_RE       = re.compile(r'^\s{1,12}"[^"]+"\s+([a-z][a-z0-9_]+)\s+<', re.MULTILINE)
_GUARDRAIL_NAME_RE  = re.compile(r'\[DEFINE_GUARDRAIL:\s*"[^"]+"\s+([A-Z][A-Za-z0-9]+)\]')
_API_NAME_RE        = re.compile(r'"[^"]+"\s+([A-Z][A-Za-z0-9]+)\s+<(?:none|apikey|oauth)>')


def _extract_symbol_table(
    block_4b: str,
    block_4c: str,
    block_4d: str,
) -> dict[str, list[str]]:
    """
    Extract all defined names from Round 1 blocks.
    Returns a dict mapping category → list of names.
    """
    table: dict[str, list[str]] = {
        "constraint_aspects": [],   # CamelCase AspectNames from DEFINE_CONSTRAINTS
        "variables":          [],   # snake_case var names from DEFINE_VARIABLES
        "files":              [],   # snake_case file names from DEFINE_FILES
        "guardrails":         [],   # PascalCase GuardrailNames
        "apis":               [],   # PascalCase ApiNames
    }

    if block_4b:
        table["constraint_aspects"] = _CONSTRAINT_NAME_RE.findall(block_4b)

    if block_4c:
        # VARIABLES block comes before FILES block; split on [END_VARIABLES]
        parts = block_4c.split("[END_VARIABLES]")
        var_block  = parts[0] if len(parts) > 1 else block_4c
        file_block = parts[1] if len(parts) > 1 else ""
        table["variables"] = _VARIABLE_NAME_RE.findall(var_block)
        table["files"]     = _FILE_NAME_RE.findall(file_block)

    if block_4d:
        table["guardrails"] = _GUARDRAIL_NAME_RE.findall(block_4d)
        table["apis"]       = _API_NAME_RE.findall(block_4d)

    return table


def _format_symbol_table(symbol_table: dict[str, list[str]]) -> str:
    """
    Render the symbol table as a concise, LLM-readable text block.
    """
    lines = []
    mapping = {
        "constraint_aspects": ("CONSTRAINTS  (use as AspectName_violation in [THROW])",
                               "AspectName_violation"),
        "variables":          ("VARIABLES    (use in <REF> ... </REF>)", None),
        "files":              ("FILES        (use in <REF> ... </REF>)", None),
        "guardrails":         ("GUARDRAILS   (use in [INVOKE GuardrailName ...])", None),
        "apis":               ("APIS         (use in [CALL ApiName ...])", None),
    }
    for key, (label, suffix) in mapping.items():
        names = symbol_table.get(key, [])
        if names:
            if suffix:
                formatted = ", ".join(f"{n}_{suffix.split('_')[1]}" for n in names)
            else:
                formatted = ", ".join(names)
            lines.append(f"{label}:\n  {formatted}")
    return "\n\n".join(lines) if lines else "(no symbols defined in earlier blocks)"


# ── Assembly + Review Summary ─────────────────────────────────────────────────

def _assemble_spl(
    skill_id: str,
    block_4a: str,
    block_4b: str,
    block_4c: str,
    block_4d: str,
    block_4e: str,
) -> str:
    """
    Concatenate all blocks in canonical SPL order with a header comment.
    Strips any accidental markdown fences the LLM may have added.
    """
    header = (
        f"# SPL specification — {skill_id}\n"
        f"# Generated by skill-to-cnlp pipeline\n"
    )
    blocks = [header]
    for block in (block_4a, block_4b, block_4c, block_4d, block_4e):
        cleaned = _strip_fences(block.strip())
        if cleaned:
            blocks.append(cleaned)

    return "\n\n".join(blocks)


def _strip_fences(text: str) -> str:
    """Remove leading/trailing markdown code fences if present."""
    lines = text.splitlines()
    if lines and lines[0].startswith("```"):
        lines = lines[1:]
    if lines and lines[-1].startswith("```"):
        lines = lines[:-1]
    return "\n".join(lines).strip()


def _build_review_summary(
    classified_clauses: list[ClassifiedClause],
    interface_spec: InterfaceSpec,
) -> str:
    counts = _count_clauses(classified_clauses)
    lines = [
        "## Review Summary\n",
        "Clauses emitted: "
        + "  ".join(f"{k.split('_')[-1]}={v}" for k, v in counts.items()),
        "",
    ]

    needs_review = [c for c in classified_clauses if c.needs_review]
    if needs_review:
        lines.append("### Items requiring human review (NEEDS_REVIEW: true)")
        for c in needs_review:
            lines.append(f"- [{c.clause_id}] {c.classification.value}: "
                         f"{c.original_text[:100]}")
        lines.append("")

    assumed = [c for c in classified_clauses if c.confidence < 0.6]
    if assumed:
        lines.append("### Low-confidence clauses (confidence < 0.6)")
        for c in assumed:
            lines.append(f"- [{c.clause_id}] confidence={c.confidence:.2f}: "
                         f"{c.original_text[:100]}")
        lines.append("")

    if interface_spec.needs_review_items:
        lines.append("### Open interface questions")
        for item in interface_spec.needs_review_items:
            lines.append(f"- {item.item}: {item.question}")
        lines.append("")

    return "\n".join(lines)


def _split_spl_output(raw_text: str) -> tuple[str, str]:
    """Legacy helper — kept for compatibility. Not used in sectioned path."""
    marker = "## Review Summary"
    idx = raw_text.find(marker)
    if idx >= 0:
        return raw_text[:idx].strip(), raw_text[idx:].strip()
    return raw_text.strip(), ""


def _count_clauses(classified_clauses: list[ClassifiedClause]) -> dict[str, int]:
    counts = {c.value: 0 for c in Classification}
    for clause in classified_clauses:
        counts[clause.classification.value] += 1
    return counts