# Skill-to-CNL-P Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!
# ============================================

# Required: LLM API Configuration
# --------------------------------------------
# Your API key for the LLM service
LLM_API_KEY=your_api_key_here

# Optional: API Base URL
# Default: https://api.rcouyi.com/v1
# Uncomment and modify if using a different endpoint:
# LLM_BASE_URL=https://api.rcouyi.com/v1

# Optional: Default Model
# Default: gpt-4o
# LLM_MODEL=gpt-4o

# Optional: Step-specific Model Overrides
# Uncomment to use different models for specific steps:
# STEP1_MODEL=gpt-4o
# STEP3_MODEL=gpt-4o
# STEP4_MODEL=gpt-4o
