"""
Prompt templates for all LLM pipeline steps.

Design principle: each prompt describes ONLY the task at hand.
No prompt mentions pipeline stages, step numbers, "prior outputs", or
any other pipeline-internal concepts. Every prompt stands alone.

Naming convention:
    P2_SYSTEM / P2_USER                — Pre-processing: File Role Resolver
    STEP1_SYSTEM / STEP1_USER          — Structure Extraction
    STEP2A_SYSTEM / STEP2A_USER        — Normative Clause Extraction + Scoring
    STEP3_SYSTEM / STEP3_USER          — Interface Inference
    STEP4_SYSTEM / STEP4_USER          — SPL Emission

USER templates contain {{placeholder}} slots filled at runtime via the
render_* helpers at the bottom of this module.
"""

from __future__ import annotations
from prompts.p2_system import v1 as p2_sys_v1
from prompts.step1_system import v1 as s1_sys_v1
from prompts.step2a_system import v1 as s2a_sys_v1
from prompts.step3_system import v3 as s3_sys_v3
from prompts.step4_system import a_v2, b_v2, c_v1, d_v2, e_v2

# ─────────────────────────────────────────────────────────────────────────────
# P2 — File Role Resolver
# ─────────────────────────────────────────────────────────────────────────────

P2_SYSTEM = p2_sys_v1

P2_USER = """\
## SKILL.md reference sentences
Lines from SKILL.md that mention other files, with ±1 line of context.
Use these to judge how critically each file is referenced.

{{skill_md_references}}

## File inventory
Each entry: path [kind, size_bytes] followed by its first lines.

{{nodes_summary}}

## Reference edges
Which files each document mentions (doc → list of referenced files):

{{edges_json}}
"""

# ─────────────────────────────────────────────────────────────────────────────
# Step 1 — Structure Extraction
# ─────────────────────────────────────────────────────────────────────────────

STEP1_SYSTEM = s1_sys_v1

STEP1_USER = """\
## Document package

{{merged_doc_text}}
"""

# ─────────────────────────────────────────────────────────────────────────────
# Step 2A — Normative Clause Extraction + Scoring
# ─────────────────────────────────────────────────────────────────────────────

STEP2A_SYSTEM = s2a_sys_v1

STEP2A_USER = """\
## Document content

{{section_bundle_text}}
"""

# ─────────────────────────────────────────────────────────────────────────────
# Step 3 — Interface Inference
# ─────────────────────────────────────────────────────────────────────────────

STEP3_SYSTEM = s3_sys_v3

STEP3_USER = """\
## A. Procedure description (ordered steps and branching logic)

{{workflow_section}}

## B. Tools, scripts, and capabilities mentioned

{{tools_section}}

## C. Inputs, outputs, and data artifacts

{{artifacts_section}}

## D. Evidence and validation requirements
These drive is_validation_gate=true on workflow steps.
Steps derived from these requirements become DEFINE_GUARDRAIL blocks.

{{evidence_section}}

## E. Examples (use for schema enrichment of entities)

{{examples_section}}

## F. NON_COMPILABLE clauses (interaction requirements source)
Extract interaction_requirements from these.

{{non_comp_clauses_json}}

## G. HARD and MEDIUM classified clauses (prerequisite and gate context)

{{hard_medium_clauses_json}}
"""

# ─────────────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Step 4 — SPL Emission (per-block prompts)
#
# Each SPL block is generated by a dedicated prompt pair.  The LLM only sees
# the grammar for the block it is writing and the data that feeds exactly that
# block.  Cross-block name consistency is enforced via a symbol table that is
# extracted after Round 1 and injected into the Round 2 (WORKER) prompt.
#
# Generation order
# ────────────────
# Round 1 (independent, can run in parallel):
#   4a  PERSONA / AUDIENCE / CONCEPTS   ← intent + notes text
#   4b  CONSTRAINTS                     ← HARD + SOFT clauses
#   4c  VARIABLES + FILES               ← InterfaceSpec entities
#   4d  APIS + GUARDRAIL                ← EXPLICIT EXEC/NETWORK capabilities
#
# Round 2 (depends on Round 1 symbol table):
#   4e  WORKER                          ← workflow steps + MEDIUM + NON clauses
#                                          + symbol table from Round 1
#
# Shared annotation convention (referenced in every block prompt):
#   # SOURCE_REF: <file>:<clause_id>
#   # CONFIDENCE: <float 0.0-1.0>
#   # NEEDS_REVIEW: true | false
#   # ASSUMED: <reason>          (when provenance != EXPLICIT)
#   # LOW_CONFIDENCE: <reason>   (when provenance == LOW_CONFIDENCE)
#   # RISK_OVERRIDE: R=3         (when risk forced SOFT → MEDIUM)
# ─────────────────────────────────────────────────────────────────────────────

# ── 4a: PERSONA / AUDIENCE / CONCEPTS ────────────────────────────────────────

S4A_SYSTEM = a_v2

S4A_USER = """\
Source material (verbatim from the original document):

{{context_text}}
"""

# ── 4b: CONSTRAINTS ───────────────────────────────────────────────────────────

S4B_SYSTEM = b_v2

S4B_USER = """\
Classified requirements (HARD and SOFT only — emit MEDIUM and NON as instructed):

{{constraints_json}}
"""

# ── 4c: VARIABLES + FILES ─────────────────────────────────────────────────────

S4C_SYSTEM = c_v1

S4C_USER = """\
Data entities:

{{entities_json}}
"""

# ── 4d: APIS + GUARDRAIL ──────────────────────────────────────────────────────

S4D_SYSTEM = d_v2

S4D_USER = """\
## Validation steps (is_validation_gate=true) → DEFINE_GUARDRAIL

{{validation_steps_json}}

## Network steps (effects contains NETWORK) → DEFINE_APIS

{{network_steps_json}}
"""

# ── 4e: WORKER ────────────────────────────────────────────────────────────────

S4E_SYSTEM = e_v2

S4E_USER = """\
## A. Workflow steps (for MAIN_FLOW — excludes validation and network steps)

{{workflow_steps_json}}

## B. Original workflow prose (for branching logic and step ordering)

{{workflow_prose}}

## C. Interaction requirements (for [INPUT DISPLAY ...] gates in MAIN_FLOW)

{{interaction_requirements_json}}

## D. MEDIUM clauses (for ALTERNATIVE_FLOW — one block per clause)

{{medium_clauses_json}}

## E. Validation steps (for EXCEPTION_FLOW — one block per validation gate)

{{validation_steps_json}}

## F. Success criteria and examples (for [OUTPUTS] annotation and [EXAMPLES])

{{success_and_examples}}
"""


# ─────────────────────────────────────────────────────────────────────────────
# Render helpers
# ─────────────────────────────────────────────────────────────────────────────

def render_p2_user(
    skill_md_references: str,
    nodes_summary: str,
    edges_json: str,
) -> str:
    return (P2_USER
            .replace("{{skill_md_references}}", skill_md_references)
            .replace("{{nodes_summary}}", nodes_summary)
            .replace("{{edges_json}}", edges_json))


def render_step1_user(merged_doc_text: str) -> str:
    return STEP1_USER.replace("{{merged_doc_text}}", merged_doc_text)


def render_step2a_user(section_bundle_text: str) -> str:
    return STEP2A_USER.replace("{{section_bundle_text}}", section_bundle_text)


def render_step3_user(
    workflow_section: str,
    tools_section: str,
    artifacts_section: str,
    evidence_section: str,
    examples_section: str,
    non_comp_clauses_json: str,
    hard_medium_clauses_json: str,
) -> str:
    return (STEP3_USER
            .replace("{{workflow_section}}", workflow_section)
            .replace("{{tools_section}}", tools_section)
            .replace("{{artifacts_section}}", artifacts_section)
            .replace("{{evidence_section}}", evidence_section)
            .replace("{{examples_section}}", examples_section)
            .replace("{{non_comp_clauses_json}}", non_comp_clauses_json)
            .replace("{{hard_medium_clauses_json}}", hard_medium_clauses_json))


def render_s4a_user(context_text: str) -> str:
    return S4A_USER.replace("{{context_text}}", context_text)


def render_s4b_user(constraints_json: str) -> str:
    return S4B_USER.replace("{{constraints_json}}", constraints_json)


def render_s4c_user(entities_json: str) -> str:
    return S4C_USER.replace("{{entities_json}}", entities_json)


def render_s4d_user(validation_steps_json: str, network_steps_json: str) -> str:
    return (S4D_USER
            .replace("{{validation_steps_json}}", validation_steps_json)
            .replace("{{network_steps_json}}", network_steps_json))


def render_s4e_user(
    workflow_steps_json: str,
    workflow_prose: str,
    interaction_requirements_json: str,
    medium_clauses_json: str,
    validation_steps_json: str,
    success_and_examples: str,
    symbol_table: str,
) -> tuple:
    system = S4E_SYSTEM.replace("{{symbol_table}}", symbol_table)
    user = (S4E_USER
            .replace("{{workflow_steps_json}}", workflow_steps_json)
            .replace("{{workflow_prose}}", workflow_prose)
            .replace("{{interaction_requirements_json}}", interaction_requirements_json)
            .replace("{{medium_clauses_json}}", medium_clauses_json)
            .replace("{{validation_steps_json}}", validation_steps_json)
            .replace("{{success_and_examples}}", success_and_examples))
    return system, user