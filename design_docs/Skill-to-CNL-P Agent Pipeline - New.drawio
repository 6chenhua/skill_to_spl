        </mxCell>
        <mxCell id="fCP3ZVzkIydIxqKMDIIO-22" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;&lt;b&gt;flow_id&lt;/b&gt;&quot;: &quot;exc-001&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;&lt;b&gt;condition&lt;/b&gt;&quot;: &quot;fill_fillable_fields.py script prints error messages&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;&lt;b&gt;log_ref&lt;/b&gt;&quot;: &quot;&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;&lt;b&gt;steps&lt;/b&gt;&quot;: [ ...... ],&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;&lt;b&gt;source_text&lt;/b&gt;&quot;: &quot;This script will verify that the field IDs and values you provide are valid; if it prints error messages, correct the appropriate fields and try again.&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;&lt;b&gt;provenance&lt;/b&gt;&quot;: &quot;EXPLICIT&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;" vertex="1">
