        <mxCell id="fCP3ZVzkIydIxqKMDIIO-16" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;[{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;step_id&lt;/b&gt;&quot;: &quot;step.check_fillable_fields&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;description&lt;/b&gt;&quot;: &quot;Check if the PDF has fillable form fields&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;prerequisites&lt;/b&gt;&quot;: [&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;document_pdf&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; ],&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;produces&lt;/b&gt;&quot;: [],&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;is_validation_gate&lt;/b&gt;&quot;: false,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;effects&lt;/b&gt;&quot;: [&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;EXEC&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; ],&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;execution_mode&lt;/b&gt;&quot;: &quot;CODE&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;tool_hint&lt;/b&gt;&quot;: &quot;python scripts/check_fillable_fields&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;&lt;b&gt;source_text&lt;/b&gt;&quot;: &quot;If you need to fill out a PDF form, first check to see if the PDF has fillable form fields. Run this script from this file&#39;s directory: `python scripts/check_fillable_fields &amp;lt;file.pdf&amp;gt;`&quot;&lt;/div&gt;&lt;div&gt;},&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;......&lt;/div&gt;&lt;div&gt;]&lt;/div&gt;" vertex="1">
