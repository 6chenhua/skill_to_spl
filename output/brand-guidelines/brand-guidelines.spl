# SPL specification — brand-guidelines
# Generated by skill-to-cnlp pipeline


[DEFINE_PERSONA:]
    ROLE: Applies Anthropic's official brand colors and typography to any sort of artifact that may benefit from having Anthropic's look-and-feel.
    DOMAIN: branding
[END_PERSONA]

[DEFINE_CONSTRAINTS:]
    Fonts should be pre-installed in your environment for best results (SKILL.md)
[END_CONSTRAINTS]

[DEFINE_VARIABLES:]
""" Assumed: Configuration constant for the system """
READONLY system_mode: text = "production"
""" Assumed: User preferences """
user_preferences: { theme: text, notifications: boolean }
[END_VARIABLES]

[DEFINE_FILES:]
""" Assumed: Log file for system events """
LOG system_log < >: text
""" Assumed: User uploaded images """
user_images < >: image
""" Assumed: Audio files for notifications """
notification_sounds < >: audio
[END_FILES]

[DEFINE_WORKER: "STATIC_DESCRIPTION" WorkerName]
[INPUTS]
[END_INPUTS]
[OUTPUTS]
[END_OUTPUTS]
[MAIN_FLOW]
[END_MAIN_FLOW]
[END_WORKER]